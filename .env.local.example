# Firebase web app config (copy to .env.local and fill in).
# Get these from Firebase console -> Project settings -> Your apps -> Web app.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Static super-admin account. The user who signs up / signs in with this email
# is always granted the `admin` role and can manage everyone's roles at /admin/users.
# The password gates sign-up of this reserved email. Change these before deploying.


